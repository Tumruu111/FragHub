// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String
  role      Roles    @default(User)
  orders    Order[]  @relation("UserOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Listing {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  status    ListingStatus  @default(in_stock)
  title     String
  size      String
  vibe      Vibe[]
  picture   String
  price     Decimal        @db.Decimal(10,2)
  stock     Int            @default(1)

  orders    Order[]        @relation("ListingOrders")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  status          OrderStatus  @default(pending)

  userId          String       @db.ObjectId
  user            User         @relation("UserOrders", fields: [userId], references: [id])

  listingId       String       @db.ObjectId
  listing         Listing      @relation("ListingOrders", fields: [listingId], references: [id])

  buyerConfirmed  Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  completedAt     DateTime?
  cancelledAt     DateTime?
}

enum OrderStatus {
  pending
  completed
  cancelled
}

enum ListingStatus {
  in_stock
  out_of_order
}

enum Vibe {
  FRESH        @map("Шинэлэг")
  FLORAL       @map("Цэцэглэг")
  WOODY        @map("Модлог")
  CITRUS       @map("Ситрус")
  AMBER        @map("Амбер төрлийн үнэр")
  GOURMAND     @map("Амттан төрлийн үнэр")
  SPORTY       @map("Спортлог")
  SWEET        @map("Чихэрлэг")
  EARTHY
  SPICY
  AROMATIC
  FRUITY       @map("Жимслэг")
  GREEN        @map("Ногоон")
  LEATHER
  MUSK
}

enum Roles {
  Admin
  User
}