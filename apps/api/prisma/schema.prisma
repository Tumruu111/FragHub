generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Roles    @default(User)

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Listing {
  id        String         @id @default(uuid())
  status    ListingStatus  @default(in_stock)
  title     String
  size      String
  vibe      Vibe[]
  picture   String
  price     Decimal        @db.Decimal(10,2)
  stock     Int            @default(1)

  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String       @id @default(uuid())
  status          OrderStatus  @default(pending)

  userId          String
  user            User         @relation(fields: [userId], references: [id])

  listingId       String
  listing         Listing      @relation(fields: [listingId], references: [id])

  buyerConfirmed  Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  completedAt     DateTime?
  cancelledAt     DateTime?
}

enum OrderStatus {
  pending
  completed
  cancelled
}

enum ListingStatus {
  in_stock
  out_of_order
}

enum Vibe {
  FRESH
  FLORAL
  WOODY
  CITRUS
  AMBER
  GOURMAND
  SPORTY
  SWEET
  EARTHY
  SPICY
  AROMATIC
  FRUITY
  GREEN
  LEATHER
  MUSK
}

enum Roles {
  Admin
  User
}